{
  "name": "@groweasy/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target node22 --out-dir dist --clean --sourcemap",
    "start": "node dist/index.js",
    "lint": "node ../Docs/node_modules/eslint/bin/eslint.js --config ../Docs/eslint.config.mjs \"src/**/*.ts\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@groweasy/shared": "file:./shared",
    "compression": "1.8.1",
    "cors": "2.8.5",
    "@google/genai": "2.10.0",
    "csv-parse": "6.1.0",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.1.0",
    "multer": "2.2.0",
    "p-limit": "7.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/multer": "2.0.0",
    "@types/node": "24.10.1",
    "@types/supertest": "6.0.3",
    "supertest": "7.1.4",
    "tsup": "8.5.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
