{
  "name": "@groweasy/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target es2022 --out-dir dist --clean --dts",
    "lint": "node ../../Docs/node_modules/eslint/bin/eslint.js --config ../../Docs/eslint.config.mjs \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
